<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import view.shared.BackButton?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="dark-bg" stylesheets="@/view/tracking/StyleWeightProgress.css, @/view/shared/shared-buttons.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.tracking.WeightProgressController">
    <children>

        <VBox alignment="TOP_CENTER" spacing="25" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <!-- Title -->
            <Label styleClass="title-text" text="Weight Tracking Progress">
                <font>
                    <Font size="36.0" />
                </font>
            </Label>

            <!-- Weekly Averages Table -->
            <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="20" bottom="20" left="30" right="30" />
                </padding>

                <Label styleClass="section-label" text="Weekly Averages">
                    <padding>
                        <Insets bottom="15" />
                    </padding>
                </Label>

                <TableView fx:id="weeklyTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="weekColumn" text="Week #" prefWidth="150" styleClass="table-column" />
                        <TableColumn fx:id="weightColumn" text="Average Weight (kg)" prefWidth="200" styleClass="table-column" />
                        <TableColumn fx:id="dateColumn" text="Date Recorded" prefWidth="250" styleClass="table-column" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Current Week Progress -->
            <VBox styleClass="progress-section" spacing="10">
                <padding>
                    <Insets top="15" bottom="15" left="25" right="25" />
                </padding>

                <Label styleClass="section-label" text="Current Week Progress" />
                <Label fx:id="currentWeekLabel" styleClass="info-label" wrapText="true" />
            </VBox>

        </VBox>

        <!-- Global Back Button -->
        <BackButton onAction="#goBack" AnchorPane.topAnchor="16.0" AnchorPane.leftAnchor="16.0" />

    </children>
</AnchorPane>
