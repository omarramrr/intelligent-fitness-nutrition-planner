<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import view.shared.BackButton?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="dark-bg" stylesheets="@/view/tracking/StyleTrackBodyWeight.css, @/view/shared/shared-buttons.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.tracking.TrackBodyWeightController">
    <children>

        <VBox alignment="CENTER" spacing="30" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <!-- Title -->
            <Label styleClass="title-text" text="Track Body Weight">
                <font>
                    <Font size="36.0" />
                </font>
            </Label>

            <!-- Weight Input Section -->
            <VBox alignment="CENTER" spacing="20" styleClass="weight-section">
                <padding>
                    <Insets top="30" bottom="30" left="40" right="40" />
                </padding>

                <Label styleClass="section-label" text="Add Today's Weight" />

                <!-- Weight Input with Label -->
                <VBox alignment="CENTER" spacing="10">
                    <TextField fx:id="weightInput" promptText="Enter weight" styleClass="weight-input" prefWidth="250" alignment="CENTER" />
                    <Label styleClass="unit-label" text="(in kg)" />
                </VBox>

                <!-- Add Weight Button -->
                <Button onAction="#addTodaysWeight" prefWidth="200" styleClass="primary-btn" text="Add Weight" />
                
                <!-- Success Message Label -->
                <Label fx:id="successLabel" styleClass="success-label" wrapText="true" />
            </VBox>

            <!-- Show Progress Button -->
            <Button onAction="#showProgress" prefWidth="250" styleClass="primary-btn" text="Show Progress" />

        </VBox>

        <!-- Global Back Button -->
        <BackButton onAction="#goBack" AnchorPane.topAnchor="16.0" AnchorPane.leftAnchor="16.0" />

    </children>
</AnchorPane>
