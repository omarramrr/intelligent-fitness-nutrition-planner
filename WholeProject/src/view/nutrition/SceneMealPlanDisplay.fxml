<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import view.shared.BackButton?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="dark-bg" stylesheets="@/view/nutrition/StyleMealPlanDisplay.css, @/view/shared/shared-buttons.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.nutrition.MealPlanDisplayController">
    <children>

        <VBox alignment="TOP_CENTER" spacing="25" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <!-- Title -->
            <Label styleClass="title-text" text="1-Day Meal Plan">
                <font>
                    <Font size="36.0" />
                </font>
            </Label>

            <!-- Daily Target -->
            <Label fx:id="dailyTargetLabel" styleClass="daily-target" />

            <!-- Meals Container -->
            <VBox spacing="15" VBox.vgrow="ALWAYS">

                <!-- Breakfast Card -->
                <VBox styleClass="meal-card">
                    <padding>
                        <Insets top="15" bottom="15" left="20" right="20" />
                    </padding>
                    <Label styleClass="meal-title" text="🌅 BREAKFAST (25%)" />
                    <Label fx:id="breakfastCalories" styleClass="meal-calories" />
                    <Label fx:id="breakfastMacros" styleClass="meal-macros" wrapText="true" />
                </VBox>

                <!-- Lunch Card -->
                <VBox styleClass="meal-card">
                    <padding>
                        <Insets top="15" bottom="15" left="20" right="20" />
                    </padding>
                    <Label styleClass="meal-title" text="🌞 LUNCH (35%)" />
                    <Label fx:id="lunchCalories" styleClass="meal-calories" />
                    <Label fx:id="lunchMacros" styleClass="meal-macros" wrapText="true" />
                </VBox>

                <!-- Dinner Card -->
                <VBox styleClass="meal-card">
                    <padding>
                        <Insets top="15" bottom="15" left="20" right="20" />
                    </padding>
                    <Label styleClass="meal-title" text="🌙 DINNER (30%)" />
                    <Label fx:id="dinnerCalories" styleClass="meal-calories" />
                    <Label fx:id="dinnerMacros" styleClass="meal-macros" wrapText="true" />
                </VBox>

                <!-- Snacks Card -->
                <VBox styleClass="meal-card">
                    <padding>
                        <Insets top="15" bottom="15" left="20" right="20" />
                    </padding>
                    <Label styleClass="meal-title" text="🍎 SNACKS (10%)" />
                    <Label fx:id="snacksCalories" styleClass="meal-calories" />
                    <Label fx:id="snacksMacros" styleClass="meal-macros" wrapText="true" />
                </VBox>

            </VBox>

            <!-- Tip -->
            <Label styleClass="tip-label" text="💡 Use these targets to plan your meals throughout the day!" wrapText="true" />

        </VBox>

        <!-- Global Back Button -->
        <BackButton onAction="#goBack" AnchorPane.topAnchor="16.0" AnchorPane.leftAnchor="16.0" />

    </children>
</AnchorPane>
