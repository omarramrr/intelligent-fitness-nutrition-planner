<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="dark-bg" stylesheets="@/view/home/Style4.css, @/view/shared/shared-buttons.css, @/view/shared/shared-controls.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.home.Scene4Controller">
    <children>



        <!-- Centered Content Area -->
        <VBox fx:id="contentArea" alignment="CENTER" spacing="40" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
             
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>
            
            <!-- Welcome Title -->
            <Label fx:id="contentLabel" styleClass="title-text" text="Welcome!" />

            <!-- Main Action Buttons -->
            <VBox alignment="CENTER" spacing="20">

                <!-- Track Body Weight Button -->
                <Button onAction="#trackBodyWeight" prefWidth="300" styleClass="primary-btn" text="Track Body Weight" />

                <!-- Generate Workout Button -->
                <Button onAction="#generateWorkout" prefWidth="300" styleClass="primary-btn" text="Generate Workout" />

                <!-- Generate Nutrition Plan Button -->
                <Button onAction="#generateNutritionPlan" prefWidth="300" styleClass="primary-btn" text="Generate Nutrition Plan" />

            </VBox>

        </VBox>

        <!-- Profile Button (Top-Right) - Moved to end for Z-order -->
        <Button onAction="#handleProfileClick" styleClass="profile-icon-btn" text="👤" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0" />

    </children>
</AnchorPane>
