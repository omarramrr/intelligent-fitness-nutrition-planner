<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="dark-bg" stylesheets="@/view/shared/Style.css, @/view/shared/shared-buttons.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.auth.Scene1Controller">

    <children>
        <!-- Centered column with title + buttons -->
        <VBox alignment="CENTER" spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

            <Label alignment="CENTER" styleClass="title-text" text="Welcome to Fitnessmanger" textAlignment="CENTER">
            <font>
               <Font size="32.0" />
            </font></Label>

            <VBox alignment="CENTER" spacing="12.0">
                <Button onAction="#onSignInClicked" prefWidth="220.0" styleClass="primary-btn" text="Sign In" />

                <Button onAction="#onSignUpClicked" prefWidth="220.0" styleClass="primary-btn" text="Sign Up" />
            </VBox>
        </VBox>
    </children>
</AnchorPane>
